rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - userId: string (required)
    //   - username: string (required, unique-ish)
    //   - email: string (required)
    //   - createdAt: timestamp (required)
    //   - photoURL: string (optional)
    //   - theme: string (optional)
    //   - prompts: list (optional)
    //   - blacklist: list (optional)
    //   - isDarkMode: bool (optional)
    //   - avatarConfig: string (optional)
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - recipientId: string (required)
    //   - content: string (required, max 1000 chars)
    //   - createdAt: timestamp (required)
    //   - isRead: bool (required)
    //   - isReported: bool (optional)
    //   - reactions: map (optional)
    //   - reply: string (optional)
    //   - isVoice: bool (optional)
    //   - voiceUrl: string (optional)
    //   - status: string (optional, delivered/read)
    //
    // Collection: analytics
    // Document ID: auto-generated (e.g., userId_date)
    // Fields:
    //   - userId: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - visits: number (required)
    //   - messagesReceived: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'username', 'email', 'createdAt']) &&
             data.userId is string &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.email is string &&
             data.createdAt is timestamp &&
             (!('prompts' in data) || data.prompts is list) &&
             (!('blacklist' in data) || data.blacklist is list) &&
             (!('theme' in data) || data.theme is string) &&
             (!('avatarConfig' in data) || data.avatarConfig is string);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['recipientId', 'content', 'createdAt', 'isRead']) &&
             data.recipientId is string &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 1000 &&
             data.createdAt is timestamp &&
             data.isRead == false &&
             (!('isVoice' in data) || data.isVoice is bool) &&
             (!('voiceUrl' in data) || data.voiceUrl is string) &&
             (!('voiceData' in data) || (data.voiceData is string && data.voiceData.size() < 900000));
    }

    function isValidAnalytics(data) {
      return data.keys().hasAll(['userId', 'date', 'visits', 'messagesReceived']) &&
             data.userId is string &&
             data.date is string &&
             data.visits is number &&
             data.messagesReceived is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true; 
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.createdAt == resource.data.createdAt;
    }

    match /messages/{messageId} {
      // Senders can read their own message if they have the ID (for read receipts)
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.recipientId) || 
                    (resource.data.status == 'delivered' || resource.data.status == 'read');
      
      allow create: if isValidMessage(request.resource.data);
      
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.recipientId) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reactions', 'reply']) && 
                     (isAuthenticated() && request.auth.uid == resource.data.recipientId));
      
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.recipientId;
    }

    match /analytics/{analyticsId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if true; // Allow anyone to start an analytics doc for a user
      allow update: if true; // Allow anyone to increment visits/messages
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.recipientId;
      allow read: if false;
    }
  }
}
